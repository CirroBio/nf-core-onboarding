// Minimal Cirro compute config: container registry + resource limits only.
// Reference process/withName blocks are dropped — they carry the reference
// pipeline's undefined constants/params/ext.args and crash the target run.
docker.registry = 'quay.io'
apptainer.registry = 'quay.io'

params {
    max_memory = 488.GB
    max_cpus = 64
    max_time = 240.h
}
