// Minimal Cirro compute config: container registry + resource limits only.
// A copied reference (sarek-style) config injects undefined constants/params that
// break the target run; Cirro applies sane default resources without them.
docker.registry     = 'quay.io'
apptainer.registry  = 'quay.io'

params {
    max_memory = 488.GB
    max_cpus   = 64
    max_time   = 240.h
}
